<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<title>SPA Metrics test</title>
	<%- renderAgent({
		spaMetrics: {
			maxPageLoadWaitTime: 1000,
			quietTime: 500,
			urlOverrides: [
				{
					match: '#network-disabled',
					monitors: ['media', 'performance'],
				},
			],
		},
	}) %>
</head>
<body>
	<h1>SPA Metrics test</h1>

	<button type="button" id="btnNavigate">Navigate</button>
	<button type="button" id="btnNavigateWithFetch">Navigate with fetch</button>
	<button type="button" id="btnNavigateWithImage">Navigate with image</button>
	<button type="button" id="btnNavigateWithSlowFetch">Navigate with slow fetch</button>
	<button type="button" id="btnNavigateWithNetworkDisabled">Navigate with network disabled</button>

	<div id="content"></div>

	<script>
		document.querySelector('#btnNavigate').addEventListener('click', function () {
			location.hash = 'page1';
		});

		document.querySelector('#btnNavigateWithFetch').addEventListener('click', function () {
			location.hash = 'page2';
			// Simulate API call after navigation
			fetch('/some-data').then(function(response) {
				return response.json();
			}).then(function(data) {
				document.getElementById('content').textContent = JSON.stringify(data);
			});
		});

		document.querySelector('#btnNavigateWithImage').addEventListener('click', function () {
			location.hash = 'page3';
			// Add image after navigation
			const img = document.createElement('img');
			img.src =
				'http://localhost:3001/user-interaction/assets/splunk-black.png?delay=300&noCache&resource=' +
				Date.now();
			document.getElementById('content').appendChild(img);
		});

		document.querySelector('#btnNavigateWithSlowFetch').addEventListener('click', function () {
			location.hash = 'slow-fetch';
			fetch('/some-data?delay=1500&resource=global-slow-fetch').catch(function () {});
		});

		document.querySelector('#btnNavigateWithNetworkDisabled').addEventListener('click', function () {
			location.hash = 'network-disabled';
			fetch('/some-data?delay=1500&resource=override-slow-fetch').catch(function () {});
		});
	</script>
</body>
</html>
