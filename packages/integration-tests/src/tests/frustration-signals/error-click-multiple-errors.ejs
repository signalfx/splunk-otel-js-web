<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<title>Error click multiple errors</title>

		<%- renderAgent({
			instrumentations: {
				frustrationSignals: {
					errorClick: {
						timeWindowMs: 2000,
						multipleErrors: 'all'
					}
				}
			}
		}) %>
	</head>
	<body>
		<h1>Error click multiple errors</h1>
		<button id="btn-multi-error">Multiple Errors</button>

		<script>
			document.addEventListener('click', () => {});

			document.getElementById('btn-multi-error').addEventListener('click', function () {
				setTimeout(function () {
					throw new TypeError('first error');
				}, 50);
				setTimeout(function () {
					throw new ReferenceError('second error');
				}, 100);
			});
		</script>
	</body>
</html>
