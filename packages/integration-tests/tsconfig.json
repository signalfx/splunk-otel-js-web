{
	"include": ["src/**/*.ts", "playwright.config.ts"],
	"compilerOptions": {
		"allowSyntheticDefaultImports": true,
		"target": "esnext",
		"moduleResolution": "nodenext",
		"module": "NodeNext",
		"strict": true,
		"noImplicitAny": true,
		"skipLibCheck": true,
		"paths": {
			"@test-kit/*": ["../test-kit/src/*"]
		}
	}
}
