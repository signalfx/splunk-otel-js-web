# Dev sandbox realm presets
#
# Copy this file to .env (already gitignored) and fill in dev/test tokens.
# The webpack dev-server reads this file at startup and exposes presets
# to the sandbox via window.__DEV_PRESETS__ (populates the "Preset"
# dropdown in the Settings modal).
#
# Each preset block is identified by a unique <ID> (the key suffix) and the
# realm is defined inside the block. To add a second preset for the same
# realm just pick a different <ID>, e.g. append `-2`:
#
#   SPLUNK_RUM_REALM_MON0=mon0
#   SPLUNK_RUM_REALM_MON0-2=mon0
#
# Supported realms: us0, us1, us2, eu0, jp0, au0, mon0, lab0
#
# Key pattern (all values scoped by <ID>):
#   SPLUNK_RUM_REALM_<ID>              realm        (required; activates the preset)
#   SPLUNK_RUM_TOKEN_<ID>              rumAccessToken
#   SPLUNK_RUM_APP_<ID>                applicationName
#   SPLUNK_RUM_ENV_<ID>                deploymentEnvironment
#   SPLUNK_RUM_BEACON_<ID>             beaconEndpoint
#   SPLUNK_RUM_RECORDER_BEACON_<ID>    recorder beaconEndpoint
#
# <ID> must match [A-Za-z0-9_-]+ and is shown in the dropdown.
#
# Examples:

# SPLUNK_RUM_REALM_US0=us0
# SPLUNK_RUM_TOKEN_US0=xxxxxxxxxxxxxxxxxxxxxxxx
# SPLUNK_RUM_APP_US0=my-app-dev
# SPLUNK_RUM_ENV_US0=dev

# SPLUNK_RUM_REALM_US0-2=us0
# SPLUNK_RUM_TOKEN_US0-2=yyyyyyyyyyyyyyyyyyyyyyyy
# SPLUNK_RUM_APP_US0-2=my-app-staging
# SPLUNK_RUM_ENV_US0-2=staging

### Realm presets:

# lab0
SPLUNK_RUM_REALM_LAB0=lab0
SPLUNK_RUM_APP_LAB0=rum-dev-sandbox
SPLUNK_RUM_ENV_LAB0=dev
SPLUNK_RUM_TOKEN_LAB0=<PASTE_TOKEN_HERE>

# rc0
SPLUNK_RUM_REALM_RC0=rc0
SPLUNK_RUM_APP_RC0=rum-dev-sandbox
SPLUNK_RUM_ENV_RC0=dev
SPLUNK_RUM_TOKEN_RC0=<PASTE_TOKEN_HERE>

# mon0
SPLUNK_RUM_REALM_MON0=mon0
SPLUNK_RUM_APP_MON0=rum-dev-sandbox
SPLUNK_RUM_ENV_MON0=dev
SPLUNK_RUM_TOKEN_MON0=<PASTE_TOKEN_HERE>
