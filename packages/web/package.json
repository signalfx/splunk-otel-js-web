{
	"name": "@splunk/otel-web",
	"version": "3.0.0",
	"description": "Splunk distribution of Open Telemetry for browser environment.",
	"keywords": [
		"splunk",
		"opentelemetry",
		"otel",
		"observability",
		"monitoring",
		"tracing",
		"browser",
		"web",
		"instrumentations",
		"telemetry"
	],
	"repository": "github:signalfx/splunk-otel-js-browser",
	"scripts": {
		"build": "npm-run-all -s build:*",
		"build:browser": "webpack --mode production --color && tsx scripts/remove-jaeger-vars.ts",
		"build:tsc": "tsc --build tsconfig.cjs.json tsconfig.esm.json",
		"typecheck:tests": "tsc --noEmit --project tsconfig.test.json",
		"dev": "npm-run-all -s dev:tsc:init -p dev:*",
		"dev:serve": "webpack serve --mode development --color",
		"dev:tsc:init": "tsc --build tsconfig.cjs.json tsconfig.esm.json",
		"dev:tsc": "tsc --build --watch tsconfig.cjs.json tsconfig.esm.json",
		"clean": "rm -rf dist .turbo",
		"wait": "wait-on dist/esm/index.js  dist/cjs/index.js"
	},
	"author": "Splunk Observability Instrumentals Team <ssg-observability-instrumentals-npm@splunk.com>",
	"license": "Apache-2.0",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"types": "dist/cjs/index.d.ts",
	"exports": {
		"types": "./dist/cjs/index.d.ts",
		"import": "./dist/esm/index.js",
		"require": "./dist/cjs/index.js"
	},
	"files": [
		"dist/cjs/**/*.js",
		"dist/cjs/**/*.js.map",
		"dist/cjs/**/*.d.ts",
		"dist/esm/**/*.js",
		"dist/esm/**/*.js.map",
		"dist/esm/**/*.d.ts"
	],
	"dependencies": {
		"@opentelemetry/api": "catalog:",
		"@opentelemetry/core": "catalog:",
		"@opentelemetry/exporter-trace-otlp-http": "catalog:",
		"@opentelemetry/exporter-zipkin": "catalog:",
		"@opentelemetry/instrumentation": "catalog:",
		"@opentelemetry/instrumentation-document-load": "catalog:",
		"@opentelemetry/instrumentation-fetch": "catalog:",
		"@opentelemetry/instrumentation-xml-http-request": "catalog:",
		"@opentelemetry/resources": "catalog:",
		"@opentelemetry/sdk-trace-base": "catalog:",
		"@opentelemetry/sdk-trace-web": "catalog:",
		"@opentelemetry/semantic-conventions": "catalog:",
		"core-js": "3.49.0",
		"nanoid": "^5.1.11",
		"shimmer": "^1.2.1",
		"web-vitals": "5.2.0"
	},
	"devDependencies": {
		"@swc/core": "^1.15.33",
		"@swc/helpers": "^0.5.21",
		"@types/shimmer": "^1.2.0",
		"dotenv": "^17.4.2",
		"fork-ts-checker-webpack-plugin": "^9.1.0",
		"npm-run-all": "^4.1.5",
		"socket.io-client": "^4.8.3",
		"source-map-loader": "^5.0.0",
		"swc-loader": "^0.2.7",
		"ts-loader": "^9.6.0",
		"wait-on": "^9.0.10",
		"webpack": "^5.106.2",
		"webpack-cli": "^7.0.3",
		"webpack-dev-server": "^5.2.5"
	},
	"bugs": {
		"url": "https://github.com/signalfx/splunk-otel-js-web/issues"
	},
	"homepage": "https://github.com/signalfx/splunk-otel-js-web#readme",
	"publishConfig": {
		"access": "public"
	}
}
