{
	"name": "@splunk/otel-web-session-recorder",
	"version": "2.5.1",
	"description": "Session recorder for Splunk Observability",
	"keywords": [
		"splunk",
		"session recorder",
		"session replay",
		"observability",
		"monitoring",
		"browser",
		"web",
		"user experience"
	],
	"repository": "github:signalfx/splunk-otel-js-browser",
	"scripts": {
		"build": "npm-run-all -s build:*",
		"build:browser": "webpack --mode production --color",
		"build:tsc": "tsc --build tsconfig.cjs.json tsconfig.esm.json",
		"dev": "npm-run-all -s dev:*",
		"dev:browser": "webpack --mode development --watch --color",
		"dev:tsc": "tsc --build --watch tsconfig.cjs.json tsconfig.esm.json",
		"clean": "rm -rf dist .turbo",
		"wait": "wait-on dist/esm/index.js  dist/cjs/index.js"
	},
	"author": "Splunk Observability Instrumentals Team <ssg-observability-instrumentals-npm@splunk.com>",
	"license": "Apache-2.0",
	"main": "dist/cjs/index.js",
	"browser": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"types": "dist/cjs/index.d.ts",
	"exports": {
		"types": "./dist/cjs/index.d.ts",
		"import": "./dist/esm/index.js",
		"require": "./dist/cjs/index.js"
	},
	"files": [
		"dist/cjs/**/*.js",
		"dist/cjs/**/*.js.map",
		"dist/cjs/**/*.d.ts",
		"dist/esm/**/*.js",
		"dist/esm/**/*.js.map",
		"dist/esm/**/*.d.ts"
	],
	"dependencies": {
		"@opentelemetry/api": "^1.9.0",
		"@opentelemetry/core": "^1.25.1",
		"@opentelemetry/resources": "^1.25.1",
		"core-js": "3.49.0",
		"fflate": "^0.8.0",
		"nanoid": "^5.1.11",
		"type-fest": "^5.6.0"
	},
	"peerDependencies": {
		"@splunk/otel-web": "workspace:*"
	},
	"devDependencies": {
		"@splunk/otel-web": "workspace:*",
		"@swc/core": "^1.15.21",
		"@swc/helpers": "^0.5.21",
		"copy-webpack-plugin": "^14.0.0",
		"fork-ts-checker-webpack-plugin": "^9.1.0",
		"npm-run-all": "^4.1.5",
		"source-map-loader": "^5.0.0",
		"swc-loader": "^0.2.7",
		"terser-webpack-plugin": "^5.4.0",
		"ts-loader": "^9.5.4",
		"wait-on": "^9.0.5",
		"webpack": "^5.105.4",
		"webpack-cli": "^7.0.2",
		"webpack-dev-server": "^5.2.3"
	},
	"bugs": {
		"url": "https://github.com/signalfx/splunk-otel-js-web/issues"
	},
	"homepage": "https://github.com/signalfx/splunk-otel-js-web#readme",
	"publishConfig": {
		"access": "public"
	}
}
