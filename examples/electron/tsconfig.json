{
	"compilerOptions": {
		"target": "ES2020",
		"allowJs": true,
		"module": "NodeNext",
		"skipLibCheck": true,
		"esModuleInterop": true,
		"noImplicitAny": true,
		"sourceMap": true,
		"outDir": "dist",
		"moduleResolution": "NodeNext",
		"resolveJsonModule": true
	},
	"include": ["src/**/*", "*.ts"]
}
