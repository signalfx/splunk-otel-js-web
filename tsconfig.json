{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"baseUrl": ".",
		"moduleResolution": "NodeNext",
		"noImplicitAny": true,
		"module": "NodeNext",
		"target": "esnext",
		"inlineSourceMap": true,
		"inlineSources": true,
		"strict": true,
		"lib": ["ESNext", "DOM"],
		"declaration": true,
		"downlevelIteration": false,
		"skipLibCheck": true,
		"experimentalDecorators": true,
		"incremental": true,
		"noEmit": true,
		"allowJs": true,
		"esModuleInterop": true,
		"paths": {
			"@test-kit/*": ["packages/test-kit/src/*"],
			"@/tests/utils": ["packages/web/tests/utils/index"],
			"@/tests/utils/*": ["packages/web/tests/utils/*"]
		}
	},
	"include": [
		"*.ts",
		"*.js",
		"*.cjs",
		".*.cjs",
		"*.mjs",
		"*.mts",
		"scripts/**/*.ts",
		"scripts/**/*.mts",
		"packages/test-kit/src/**/*.ts",
		"packages/web/scripts/remove-jaeger-vars.ts",
		"packages/**/*.test.ts",
		"packages/**/*.d.ts"
	],
	"exclude": ["node_modules", "dist"]
}
